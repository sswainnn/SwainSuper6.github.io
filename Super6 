function PredictPage({round}){
  const{isLocked:kickoffLocked,countdown}=useKickoffLock(round.kickoff);
  // Rehydrate from localStorage so state survives page refresh
  const saved=loadMyEntry(round.id);
  const[name,setName]=useState(()=>saved?.name||"");
  const[predictions,setPredictions]=useState(()=>saved?.predictions||round.fixtures.reduce((a,f)=>({...a,[f.id]:{home:1,away:1}}),{}));
  const[winner,setWinner]=useState(()=>saved?.winner||"");
  const[locked,setLocked]=useState(()=>!!saved);
  const[entry,setEntry]=useState(()=>saved||null);
  const[showAnalysis,setShowAnalysis]=useState(false);
  const[showShare,setShowShare]=useState(false);
  const inputsDisabled=locked||kickoffLocked;
  const canLock=name.trim()&&winner&&!kickoffLocked;
  const handleLock=()=>{
    if(!canLock)return;
    const e={id:`entry_${Date.now()}`,name:name.trim(),predictions,winner,lockedAt:new Date().toISOString()};
    saveEntry(round.id,e);saveMyEntry(round.id,e);setEntry(e);setLocked(true);
  };
  const handleReset=()=>{
    if(kickoffLocked)return;
    clearMyEntry(round.id);
    setPredictions(round.fixtures.reduce((a,f)=>({...a,[f.id]:{home:1,away:1}}),{}));
    setName("");setWinner("");setLocked(false);setEntry(null);
  };
  if(round.fixtures.length===0)return(
    <div style={{padding:"40px 0",textAlign:"center"}}>
      <div style={{fontSize:36,marginBottom:12}}>🕐</div>
      <div style={{color:C.muted,fontSize:15,fontWeight:600}}>Fixtures not yet announced</div>
      <div style={{color:C.dim,fontSize:12,marginTop:6}}>Check back closer to {round.dates}</div>
    </div>
  );
  return(
    <div style={{paddingTop:16,paddingBottom:16}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <Tag>{round.label} · {round.dates}</Tag>
        {kickoffLocked?<span style={{fontSize:11,fontWeight:700,color:C.red}}>🔒 CLOSED</span>
          :countdown?<span style={{fontSize:11,fontWeight:700,color:C.gold,fontFamily:"monospace"}}>⏱ {countdown}</span>:null}
      </div>
      {kickoffLocked&&<div style={{background:"rgba(240,128,128,0.07)",border:`1px solid rgba(240,128,128,0.2)`,borderRadius:8,padding:"9px 14px",marginBottom:14,textAlign:"center",fontSize:12,color:C.red}}>⚽ First match has kicked off — predictions are locked.</div>}
      <div style={{marginBottom:16}}>
        <SectionLabel>Your name</SectionLabel>
        <input value={name} onChange={e=>setName(e.target.value)} disabled={inputsDisabled} placeholder="Enter your name..."
          style={{width:"100%",background:inputsDisabled?C.bg:C.surface3,border:`1px solid ${C.border}`,borderRadius:8,padding:"11px 13px",color:inputsDisabled?C.muted:C.text,fontSize:14,fontWeight:600,outline:"none",boxSizing:"border-box"}}/>
      </div>
      <div style={{marginBottom:16}}>
        <SectionLabel>Score predictions</SectionLabel>
        <div style={{display:"flex",flexDirection:"column",gap:9}}>
          {round.fixtures.map(f=>(
            <FixtureCard key={f.id} fixture={f} prediction={predictions[f.id]}
              onChange={p=>setPredictions(prev=>({...prev,[f.id]:p}))} locked={inputsDisabled}/>
          ))}
        </div>
      </div>
      <div style={{marginBottom:20}}>
        <SectionLabel>Tournament winner</SectionLabel>
        <div style={{display:"flex",flexWrap:"wrap",gap:7}}>
          {WINNER_NOMINEES.map(w=>(
            <button key={w} disabled={inputsDisabled} onClick={()=>setWinner(w)}
              style={{padding:"7px 13px",borderRadius:20,border:"1.5px solid",borderColor:winner===w?C.gold:C.border,background:winner===w?"rgba(255,215,0,0.12)":"transparent",color:winner===w?C.gold:"#7aaa88",fontSize:12,fontWeight:700,cursor:inputsDisabled?"default":"pointer",transition:"all 0.15s"}}>
              {w}
            </button>
          ))}
        </div>
      </div>
      <div style={{background:C.bg,border:`1px solid ${C.border}`,borderRadius:9,padding:"9px 13px",marginBottom:18,display:"flex",gap:20,flexWrap:"wrap"}}>
        <span style={{fontSize:12,color:C.muted}}><strong style={{color:C.gold}}>⭐ 5 pts</strong> correct score</span>
        <span style={{fontSize:12,color:C.muted}}><strong style={{color:C.green}}>✓ 2 pts</strong> correct result</span>
      </div>
      {kickoffLocked?(
        <button disabled style={{width:"100%",padding:"15px 0",background:C.surface2,color:C.dim,fontWeight:900,fontSize:16,border:"none",borderRadius:10,cursor:"default",fontFamily:"'Impact','Arial Black',sans-serif"}}>🔒 PREDICTIONS CLOSED</button>
      ):!locked?(
        <button onClick={handleLock} disabled={!canLock}
          style={{width:"100%",padding:"15px 0",background:canLock?C.gold:C.surface2,color:canLock?"#0d2618":C.dim,fontWeight:900,fontSize:16,border:"none",borderRadius:10,cursor:canLock?"pointer":"default",fontFamily:"'Impact','Arial Black',sans-serif",transition:"all 0.2s",boxShadow:canLock?"0 4px 20px rgba(255,215,0,0.25)":"none"}}>
          {canLock?"⚽ Lock In Predictions":"Enter name + pick a winner to continue"}
        </button>
      ):(
        <div style={{display:"flex",gap:9}}>
          <button onClick={()=>setShowShare(true)} style={{flex:1,padding:"12px 0",background:C.gold,color:"#0d2618",fontWeight:700,fontSize:13,border:"none",borderRadius:10,cursor:"pointer"}}>📤 Share Predictions</button>
          <button onClick={handleReset} style={{padding:"12px 16px",background:"transparent",color:C.muted,fontWeight:700,fontSize:12,border:`1px solid ${C.border}`,borderRadius:10,cursor:"pointer"}}>New Entry</button>
        </div>
      )}
      {showShare&&entry&&<ShareModal entry={entry} fixtures={round.fixtures} roundId={round.id} onClose={()=>setShowShare(false)}/>}
    </div>
  );
}

// ── RESULTS PAGE ───────────────────────────────────────────────────
function ResultsPage({round}){
  const[entries,setEntries]=useState(()=>loadEntries(round.id));
  const[actuals,setActuals]=useState(()=>loadActuals(round.id));
  const[editActuals,setEditActuals]=useState(false);
  const[draft,setDraft]=useState(()=>loadActuals(round.id));
  const[expanded,setExpanded]=useState(null);
  const[importCode,setImportCode]=useState("");
  const[importError,setImportError]=useState("");
  const saveActs=()=>{store(aKey(round.id),draft);setActuals(draft);setEditActuals(false);};
  const handleImport=()=>{
    const d=decodeShare(importCode.trim(),round.fixtures);
    if(!d){setImportError("Invalid code — check you copied it fully and are on the right round.");return;}
    if(d.roundId&&d.roundId!==round.id){
      const label=ROUNDS.find(r=>r.id===d.roundId)?.label||d.roundId;
      setImportError(`This code is for ${label}. Switch to that round tab to import it.`);return;
    }
    const e={...d,id:`import_${Date.now()}`,lockedAt:new Date().toISOString()};
    saveEntry(round.id,e);setEntries(loadEntries(round.id));setImportCode("");setImportError("");
  };
  const[confirmRemove,setConfirmRemove]=useState(null);
  const handleRemove=(entryId)=>{
    removeEntry(round.id,entryId);
    setEntries(loadEntries(round.id));
    setExpanded(null);setConfirmRemove(null);
  };
  const ranked=[...entries].sort((a,b)=>roundPoints(b,round.fixtures,actuals)-roundPoints(a,round.fixtures,actuals));
  const hasActuals=round.fixtures.some(f=>actuals[f.id]);
  if(round.fixtures.length===0)return<div style={{padding:"40px 0",textAlign:"center",color:C.muted,fontSize:14}}>No fixtures for this round yet.</div>;
  return(
    <div style={{paddingTop:16,paddingBottom:16}}>
      <div style={{marginBottom:22}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
          <SectionLabel>Actual scores</SectionLabel>
          {!editActuals
            ?<button onClick={()=>setEditActuals(true)} style={{background:"transparent",border:`1px solid ${C.border}`,color:C.muted,borderRadius:6,padding:"4px 10px",cursor:"pointer",fontSize:11}}>✏️ Edit</button>
            :<button onClick={saveActs} style={{background:C.gold,color:"#0d2618",border:"none",borderRadius:6,padding:"4px 10px",cursor:"pointer",fontSize:11,fontWeight:700}}>SAVE</button>}
        </div>
        <div style={{display:"flex",flexDirection:"column",gap:7}}>
          {round.fixtures.map(f=>(
            <div key={f.id} style={{background:C.surface3,border:`1px solid ${C.border}`,borderRadius:9,padding:"9px 14px",display:"flex",alignItems:"center",justifyContent:"space-between",gap:8}}>
              <div style={{flex:1,textAlign:"right",fontSize:12,color:C.text,fontWeight:600}}>{f.home}</div>
              <div style={{display:"flex",alignItems:"center",gap:6}}>
                <ScoreInput small value={draft[f.id]?.home??""} onChange={v=>setDraft(p=>({...p,[f.id]:{...p[f.id],home:v}}))} disabled={!editActuals}/>
                <span style={{color:C.muted,fontWeight:900}}>–</span>
                <ScoreInput small value={draft[f.id]?.away??""} onChange={v=>setDraft(p=>({...p,[f.id]:{...p[f.id],away:v}}))} disabled={!editActuals}/>
              </div>
              <div style={{flex:1,fontSize:12,color:C.text,fontWeight:600}}>{f.away}</div>
            </div>
          ))}
        </div>
        {!hasActuals&&<div style={{textAlign:"center",marginTop:7,fontSize:11,color:C.dim}}>Enter scores above to calculate points</div>}
      </div>
      <div style={{marginBottom:22}}>
        <SectionLabel>Round leaderboard</SectionLabel>
        {ranked.length===0?<div style={{textAlign:"center",color:C.dim,padding:"24px 0",fontSize:13}}>No entries yet.</div>
          :ranked.map((entry,idx)=>{
            const pts=roundPoints(entry,round.fixtures,actuals);
            const isOpen=expanded===entry.id;
            return(
              <div key={entry.id} style={{marginBottom:7}}>
                <div onClick={()=>setExpanded(isOpen?null:entry.id)}
                  style={{background:idx===0&&hasActuals?`linear-gradient(135deg,#1a3a10,${C.surface3})`:C.surface3,border:`1px solid ${idx===0&&hasActuals?C.gold:C.border}`,borderRadius:isOpen?"10px 10px 0 0":10,padding:"11px 14px",display:"flex",alignItems:"center",gap:10,cursor:"pointer"}}>
                  <div style={{width:26,height:26,borderRadius:"50%",background:idx===0&&hasActuals?C.gold:C.surface2,display:"flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:900,color:idx===0&&hasActuals?"#0d2618":C.muted,flexShrink:0}}>
                    {idx===0&&hasActuals?"🥇":idx+1}
                  </div>
                  <div style={{flex:1}}>
                    <div style={{fontWeight:700,color:C.text,fontSize:13}}>{entry.name}</div>
                    <div style={{fontSize:11,color:C.muted}}>Winner: {entry.winner}</div>
                  </div>
                  <div style={{textAlign:"right"}}>
                    <div style={{fontSize:20,fontWeight:900,color:C.gold,fontFamily:"'Impact','Arial Black',sans-serif"}}>{pts}</div>
                    <div style={{fontSize:10,color:C.muted}}>PTS</div>
                  </div>
                  <span style={{color:C.muted,fontSize:11}}>{isOpen?"▲":"▼"}</span>
                </div>
                {isOpen&&(
                  <div onClick={e=>e.stopPropagation()} style={{background:"#0a1a0f",border:`1px solid ${C.border}`,borderTop:"none",borderRadius:"0 0 10px 10px",padding:"11px 14px"}}>
                    {round.fixtures.map(f=>{
                      const pred=entry.predictions[f.id];
                      const actual=actuals[f.id];
                      const p=actual?calcPoints(pred,actual):null;
                      return(
                        <div key={f.id} style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"5px 0",borderBottom:`1px solid ${C.surface2}`}}>
                          <span style={{fontSize:11,color:C.muted,width:56}}>{f.date}</span>
                          <span style={{fontSize:12,color:C.text,flex:1,textAlign:"center"}}>{f.home} <strong style={{color:C.gold}}>{pred.home}–{pred.away}</strong> {f.away}</span>
                          {p!==null&&<span style={{fontSize:11,fontWeight:700,color:p===5?C.gold:p===2?C.green:C.red,width:42,textAlign:"right"}}>{p===5?"⭐ 5":p===2?"✓ 2":"✗ 0"}</span>}
                        </div>
                      );
                    })}
                  <div style={{marginTop:10,display:"flex",justifyContent:"flex-end"}}>
                    {confirmRemove===entry.id?(
                      <div style={{display:"flex",alignItems:"center",gap:8}}>
                        <span style={{fontSize:11,color:C.red}}>Remove this entry?</span>
                        <button onClick={e=>{e.stopPropagation();handleRemove(entry.id);}} style={{padding:"4px 10px",background:C.red,color:"#fff",border:"none",borderRadius:6,cursor:"pointer",fontSize:11,fontWeight:700}}>Yes, remove</button>
                        <button onClick={e=>{e.stopPropagation();setConfirmRemove(null);}} style={{padding:"4px 10px",background:"transparent",color:C.muted,border:`1px solid ${C.border}`,borderRadius:6,cursor:"pointer",fontSize:11}}>Cancel</button>
                      </div>
                    ):(
                      <button onClick={e=>{e.stopPropagation();setConfirmRemove(entry.id);}} style={{padding:"4px 10px",background:"transparent",color:C.red,border:`1px solid rgba(240,128,128,0.3)`,borderRadius:6,cursor:"pointer",fontSize:11}}>🗑 Remove</button>
                    )}
                  </div>
                  </div>
                )}
              </div>
            );
          })}
      </div>
      <div style={{background:C.surface3,border:`1px solid ${C.border}`,borderRadius:11,padding:14,marginBottom:18}}>
        <SectionLabel>Import a friend's entry</SectionLabel>
        <input value={importCode} onChange={e=>{setImportCode(e.target.value);setImportError("");}}
          placeholder="Paste import code here..."
          style={{width:"100%",background:C.bg,border:`1px solid ${C.border}`,borderRadius:8,padding:"9px 11px",color:C.text,fontSize:12,fontFamily:"monospace",outline:"none",boxSizing:"border-box"}}/>
        {importError&&<div style={{color:C.red,fontSize:11,marginTop:5}}>{importError}</div>}
        <button onClick={handleImport} disabled={!importCode.trim()}
          style={{marginTop:7,width:"100%",padding:"9px 0",background:importCode.trim()?C.gold:C.surface2,color:importCode.trim()?"#0d2618":C.dim,fontWeight:700,fontSize:12,border:"none",borderRadius:8,cursor:importCode.trim()?"pointer":"default"}}>
          IMPORT ENTRY
        </button>
      </div>
      <div style={{background:C.bg,border:`1px solid ${C.border}`,borderRadius:9,padding:"9px 13px",display:"flex",gap:16,flexWrap:"wrap"}}>
        <span style={{fontSize:12,color:C.muted}}><strong style={{color:C.gold}}>⭐ 5 pts</strong> correct score</span>
        <span style={{fontSize:12,color:C.muted}}><strong style={{color:C.green}}>✓ 2 pts</strong> correct result</span>
        <span style={{fontSize:12,color:C.muted}}><strong style={{color:C.red}}>✗ 0 pts</strong> wrong result</span>
      </div>
    </div>
  );
}

