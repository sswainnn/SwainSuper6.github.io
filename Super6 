                  {["TEAM","P","W","D","L","GF","GA","GD","PTS"].map(h=>(
                    <div key={h} style={{textAlign:h==="TEAM"?"left":"center",fontSize:10,color:h==="PTS"?C.gold:C.muted,fontWeight:700}}>{h}</div>
                  ))}
                </div>
                {rows.map((row,i)=>(
                  <div key={row.name} style={{padding:"9px 12px",borderTop:`1px solid ${C.border}`,background:i<2?"rgba(126,212,160,0.04)":"transparent",display:"grid",gridTemplateColumns:"1fr 28px 28px 28px 28px 36px 36px 36px 40px",alignItems:"center"}}>
                    <div style={{fontSize:12,fontWeight:700,color:C.text,display:"flex",alignItems:"center",gap:6}}>
                      {i<2&&<span style={{width:3,height:14,background:C.green,borderRadius:2,display:"inline-block"}}/>}
                      {i===2&&<span style={{width:3,height:14,background:"transparent",borderRadius:2,display:"inline-block"}}/>}
                      {row.name}
                    </div>
                    {["P","W","D","L","GF","GA","GD","Pts"].map(k=>(
                      <div key={k} style={{textAlign:"center",fontSize:12,color:k==="Pts"?C.gold:hasData?C.text:C.dim,fontWeight:k==="Pts"?900:400}}>
