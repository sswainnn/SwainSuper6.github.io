                      </div>
                    ))}
                  </div>
                ))}
                {!hasData&&<div style={{padding:"10px 14px",textAlign:"center",fontSize:12,color:C.dim}}>No results entered yet. Add scores above.</div>}
                <div style={{padding:"7px 14px",background:C.bg,display:"flex",gap:16}}>
                  <span style={{fontSize:10,color:C.muted,display:"flex",alignItems:"center",gap:5}}>
                    <span style={{width:3,height:10,background:C.green,borderRadius:2,display:"inline-block"}}/> Qualify
                  </span>
                </div>
              </div>
            );
          })()}
        </>
      )}
    </div>
  );
}

// ── BRACKET PAGE ───────────────────────────────────────────────────
function BracketPage(){
  const[bracket,setBracket]=useState(loadBracket);
  const[editing,setEditing]=useState(false);
  const[draft,setDraft]=useState(null);
  const startEdit=()=>{setDraft(JSON.parse(JSON.stringify(bracket)));setEditing(true);};
  const cancelEdit=()=>{setDraft(null);setEditing(false);};
  const saveEdit=()=>{store(BRACKET_KEY,draft);setBracket(draft);cancelEdit();};
  const updateTeam=(ri,mi,side,val)=>{const next=JSON.parse(JSON.stringify(draft));next[ri].matches[mi][side]=val;setDraft(next);};
  const display=editing?draft:bracket;
  const anyPopulated=bracket.some(r=>r.matches.some(m=>m.home||m.away));
  const finalMatch=bracket[bracket.length-1]?.matches[0];
  const hasFinalTeams=finalMatch?.home&&finalMatch?.away;
  return(
    <div style={{paddingTop:16,paddingBottom:16}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <SectionLabel>Knockout stages</SectionLabel>
        {!editing
          ?<button onClick={startEdit} style={{background:"transparent",border:`1px solid ${C.border}`,color:C.muted,borderRadius:6,padding:"5px 11px",cursor:"pointer",fontSize:11}}>✏️ Edit Teams</button>
          :<div style={{display:"flex",gap:8}}>
            <button onClick={cancelEdit} style={{background:"transparent",border:`1px solid ${C.border}`,color:C.muted,borderRadius:6,padding:"5px 11px",cursor:"pointer",fontSize:11}}>Cancel</button>
            <button onClick={saveEdit} style={{background:C.gold,color:"#0d2618",border:"none",borderRadius:6,padding:"5px 11px",cursor:"pointer",fontSize:11,fontWeight:700}}>SAVE</button>
          </div>}
      </div>
      {!anyPopulated&&!editing&&(
        <div style={{background:"rgba(255,215,0,0.04)",border:`1px solid rgba(255,215,0,0.08)`,borderRadius:10,padding:"14px 16px",marginBottom:18,textAlign:"center"}}>
          <div style={{fontSize:28,marginBottom:8}}>🏆</div>
          <div style={{fontSize:13,color:C.muted,fontWeight:600,marginBottom:4}}>Bracket awaiting teams</div>
          <div style={{fontSize:12,color:C.dim}}>Teams will auto-populate as they qualify.<br/>Tap "Edit Teams" to add them manually.</div>
        </div>
      )}
      {hasFinalTeams&&!editing&&(
        <div style={{background:`linear-gradient(135deg,#1a3010,${C.surface2})`,border:`2px solid ${C.gold}`,borderRadius:14,padding:"14px 18px",marginBottom:20,textAlign:"center",boxShadow:`0 0 30px rgba(255,215,0,0.12)`}}>
          <div style={{fontSize:10,color:C.gold,fontWeight:700,letterSpacing:3,marginBottom:8}}>THE FINAL · JUL 27</div>
          <div style={{display:"flex",alignItems:"center",justifyContent:"center",gap:16}}>
            <div style={{fontSize:15,fontWeight:700,color:C.text}}>{finalMatch.home}</div>
            <div style={{fontSize:22}}>🆚</div>
            <div style={{fontSize:15,fontWeight:700,color:C.text}}>{finalMatch.away}</div>
          </div>
          <div style={{fontSize:11,color:C.muted,marginTop:6}}>MetLife Stadium, New York/New Jersey</div>
        </div>
      )}
      {display.map((round,ri)=>{
        const isFinal=round.id==="final";
        const cols=round.matches.length>=8?2:1;
        return(
          <div key={round.id} style={{marginBottom:22}}>
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:10}}>
              <div style={{height:1,flex:1,background:C.border}}/>
              <span style={{fontSize:11,fontWeight:900,color:isFinal?C.gold:C.muted,letterSpacing:2,whiteSpace:"nowrap"}}>{isFinal?"🏆 ":""}{round.label.toUpperCase()}</span>
              <span style={{fontSize:10,color:C.dim}}>{round.matchday}</span>
              <div style={{height:1,flex:1,background:C.border}}/>
            </div>
            <div style={{display:"grid",gridTemplateColumns:cols===2?"1fr 1fr":"1fr",gap:8}}>
              {round.matches.map((match,mi)=>{
                const has=match.home||match.away;
                return(
                  <div key={match.id} style={{background:has?`linear-gradient(135deg,${C.surface3},${C.surface2})`:C.surface2,border:`1px solid ${has?C.border:"#0f2416"}`,borderRadius:10,padding:"10px 12px",minHeight:isFinal?72:60}}>
                    {editing?(
                      <div style={{display:"flex",flexDirection:"column",gap:5}}>
                        <div style={{fontSize:9,color:C.muted,fontWeight:700,letterSpacing:1}}>MATCH {match.id.replace("k","")}</div>
                        <input value={draft[ri].matches[mi].home} onChange={e=>updateTeam(ri,mi,"home",e.target.value)}
                          placeholder="Home team..." style={{background:C.bg,border:`1px solid ${C.border}`,borderRadius:6,padding:"5px 9px",color:C.text,fontSize:12,outline:"none",width:"100%",boxSizing:"border-box"}}/>
                        <input value={draft[ri].matches[mi].away} onChange={e=>updateTeam(ri,mi,"away",e.target.value)}
                          placeholder="Away team..." style={{background:C.bg,border:`1px solid ${C.border}`,borderRadius:6,padding:"5px 9px",color:C.text,fontSize:12,outline:"none",width:"100%",boxSizing:"border-box"}}/>
                      </div>
                    ):has?(
                      <div>
                        <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                          <div style={{width:4,height:4,borderRadius:"50%",background:C.green}}/>
                          <div style={{fontSize:12,fontWeight:700,color:C.text}}>{match.home||"TBD"}</div>
                        </div>
                        <div style={{fontSize:10,color:C.muted,paddingLeft:10,marginBottom:4}}>vs</div>
                        <div style={{display:"flex",alignItems:"center",gap:6}}>
                          <div style={{width:4,height:4,borderRadius:"50%",background:C.blue}}/>
                          <div style={{fontSize:12,fontWeight:700,color:C.text}}>{match.away||"TBD"}</div>
                        </div>
                      </div>
                    ):(
                      <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",height:"100%",gap:4,opacity:0.5}}>
                        <div style={{fontSize:18}}>⚽</div>
                        <div style={{fontSize:10,color:C.dim,letterSpacing:1}}>TBD</div>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  );
}

// ── ROOT APP ───────────────────────────────────────────────────────
const TABS=[
  {id:"predict",label:"Predict",icon:"⚽"},
  {id:"results",label:"Results",icon:"📊"},
  {id:"league",label:"League",icon:"🏅"},
  {id:"bracket",label:"Bracket",icon:"🗂"},
];

function App(){
  const[tab,setTab]=useState("predict");
  const[activeRound,setActiveRound]=useState(ROUNDS[0].id);
  const round=ROUNDS.find(r=>r.id===activeRound);
  return(
    <div style={{minHeight:"100vh",background:`linear-gradient(180deg,${C.surface},${C.bg})`,fontFamily:"'Segoe UI',system-ui,sans-serif",paddingBottom:70}}>
      <div style={{background:`linear-gradient(135deg,#0d2618,#0a1f13)`,borderBottom:`3px solid ${C.gold}`,padding:"14px 20px 13px",textAlign:"center",position:"relative",overflow:"hidden"}}>
        <div style={{position:"absolute",top:-60,left:"50%",transform:"translateX(-50%)",width:200,height:200,borderRadius:"50%",border:`1px solid rgba(255,215,0,0.07)`,pointerEvents:"none"}}/>
        <div style={{position:"relative"}}>
          <div style={{fontSize:10,color:C.gold,letterSpacing:4,fontWeight:700,marginBottom:2}}>FIFA WORLD CUP 2026</div>
          <h1 style={{fontSize:26,fontWeight:900,color:"#fff",margin:0,fontFamily:"'Impact','Arial Black',sans-serif",textTransform:"uppercase"}}>
            SUPER <span style={{color:C.gold}}>6</span>
          </h1>
        </div>
      </div>
      {(tab==="predict"||tab==="results")&&(
        <div style={{background:C.surface2,borderBottom:`1px solid ${C.border}`,padding:"9px 14px",display:"flex",gap:7,overflowX:"auto"}}>
          {ROUNDS.map(r=>(
            <button key={r.id} onClick={()=>setActiveRound(r.id)}
              style={{padding:"6px 15px",borderRadius:20,border:`1.5px solid ${activeRound===r.id?C.gold:C.border}`,background:activeRound===r.id?"rgba(255,215,0,0.1)":"transparent",color:activeRound===r.id?C.gold:C.muted,fontSize:12,fontWeight:700,cursor:"pointer",whiteSpace:"nowrap",flexShrink:0}}>
              {r.label}
            </button>
          ))}
        </div>
      )}
      <div style={{maxWidth:560,margin:"0 auto",padding:"0 14px"}}>
        {tab==="predict"&&<PredictPage key={activeRound} round={round}/>}
        {tab==="results"&&<ResultsPage key={activeRound} round={round}/>}
        {tab==="league"&&<LeaguePage/>}
        {tab==="bracket"&&<BracketPage/>}
      </div>
      <div style={{position:"fixed",bottom:0,left:0,right:0,background:"#071510",borderTop:`2px solid ${C.border}`,display:"flex",zIndex:100}}>
        {TABS.map(t=>(
          <button key={t.id} onClick={()=>setTab(t.id)}
            style={{flex:1,padding:"9px 0 7px",background:"transparent",border:"none",cursor:"pointer",display:"flex",flexDirection:"column",alignItems:"center",gap:3,borderTop:tab===t.id?`2px solid ${C.gold}`:"2px solid transparent",marginTop:-2}}>
            <span style={{fontSize:17}}>{t.icon}</span>
            <span style={{fontSize:9,fontWeight:700,color:tab===t.id?C.gold:C.muted,letterSpacing:1}}>{t.label.toUpperCase()}</span>
          </button>
        ))}
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>