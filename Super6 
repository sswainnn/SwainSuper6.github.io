}

// ── ANALYSIS MODAL ─────────────────────────────────────────────────
function AnalysisModal({entry,fixtures,onClose}){
  const [loading,setLoading]=useState(true);
  const [analysis,setAnalysis]=useState("");
  useEffect(()=>{
    const go=async()=>{
      const summary=fixtures.map(f=>{const p=entry.predictions[f.id];return`${f.home} ${p.home}–${p.away} ${f.away}`;}).join(", ");
      try{
        const res=await fetch("https://api.anthropic.com/v1/messages",{
          method:"POST",headers:{"Content-Type":"application/json"},
          body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,
            messages:[{role:"user",content:`You're a punchy World Cup 2026 pundit. Fan named ${entry.name} submitted: ${summary}. Winner pick: ${entry.winner}. Give 4–5 fun opinionated sentences. End with a cheeky verdict like "Solid punter", "Brave but reckless", or "Absolute wildcard". Under 120 words.`}]})
        });
        const d=await res.json();
        setAnalysis(d.content?.[0]?.text||"Great picks!");
      }catch{setAnalysis("Predictions locked in! May the football gods be with you. 🏆");}
      setLoading(false);
    };
    go();
  },[]);
  return(
    <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,0.85)",display:"flex",alignItems:"center",justifyContent:"center",zIndex:1000,padding:20}}>
