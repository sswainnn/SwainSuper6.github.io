// ── STORAGE ────────────────────────────────────────────────────────
const sKey = id=>`wc2026_entries_${id}`;
const aKey = id=>`wc2026_actuals_${id}`;
const BRACKET_KEY="wc2026_bracket";
const MATCH_SCORES_KEY="wc2026_match_scores";
const load=(k,fb)=>{try{return JSON.parse(localStorage.getItem(k)||"null")??fb;}catch{return fb;}};
const store=(k,v)=>localStorage.setItem(k,JSON.stringify(v));
const loadEntries=id=>load(sKey(id),[]);
const loadActuals=id=>load(aKey(id),{});
const loadBracket=()=>load(BRACKET_KEY,KNOCKOUT_TEMPLATE);
const loadMatchScores=()=>load(MATCH_SCORES_KEY,{});
const myEntryKey=id=>`wc2026_my_entry_${id}`;
const loadMyEntry=id=>load(myEntryKey(id),null);
const saveMyEntry=(id,entry)=>store(myEntryKey(id),entry);
const clearMyEntry=id=>localStorage.removeItem(myEntryKey(id));
function saveEntry(id,entry){
  const list=loadEntries(id);
  const idx=list.findIndex(e=>e.id===entry.id);
  if(idx>=0)list[idx]=entry;else list.push(entry);
  store(sKey(id),list);
}
function removeEntry(id,entryId){
  const list=loadEntries(id).filter(e=>e.id!==entryId);
  store(sKey(id),list);
}

// ── SCORING ────────────────────────────────────────────────────────
const getResult=(h,a)=>h>a?"H":a>h?"A":"D";
function calcPoints(pred,actual){
  if(!actual||actual.home==null||actual.away==null)return null;
  if(+pred.home===+actual.home&&+pred.away===+actual.away)return 5;
  if(getResult(+pred.home,+pred.away)===getResult(+actual.home,+actual.away))return 2;
  return 0;
}
function roundPoints(entry,fixtures,actuals){
  return fixtures.reduce((s,f)=>s+(calcPoints(entry.predictions[f.id],actuals[f.id])??0),0);
}

// ── LEAGUE TABLES ──────────────────────────────────────────────────
function buildLeagueTables(matchScores){
  const tables={};
  const blank=()=>({P:0,W:0,D:0,L:0,GF:0,GA:0,GD:0,Pts:0});
  Object.entries(GROUP_TEAMS).forEach(([g,teams])=>{
    tables[g]={};teams.forEach(t=>{tables[g][t]=blank();});
  });
  ROUNDS.forEach(round=>{
    round.fixtures.forEach(f=>{
      const score=matchScores[f.id];
      if(!score||score.home==null||score.away==null)return;
      const hg=+score.home,ag=+score.away,g=f.group;
      if(!tables[g])return;
      if(!tables[g][f.home])tables[g][f.home]=blank();
      if(!tables[g][f.away])tables[g][f.away]=blank();
      const ht=tables[g][f.home],at=tables[g][f.away];
      ht.P++;at.P++;ht.GF+=hg;ht.GA+=ag;at.GF+=ag;at.GA+=hg;
      if(hg>ag){ht.W++;ht.Pts+=3;at.L++;}
      else if(hg<ag){at.W++;at.Pts+=3;ht.L++;}
      else{ht.D++;ht.Pts++;at.D++;at.Pts++;}
    });
  });
  Object.keys(tables).forEach(g=>{
    tables[g]=Object.entries(tables[g])
      .map(([name,s])=>({name,...s,GD:s.GF-s.GA}))
      .sort((a,b)=>b.Pts-a.Pts||b.GD-a.GD||b.GF-a.GF);
  });
  return tables;
}

function buildSuperLeague(){
  const map={};
  ROUNDS.forEach(round=>{
    const actuals=loadActuals(round.id);
    loadEntries(round.id).forEach(entry=>{
      const pts=roundPoints(entry,round.fixtures,actuals);
      if(!map[entry.name])map[entry.name]={name:entry.name,rounds:{},total:0};
      map[entry.name].rounds[round.id]=(map[entry.name].rounds[round.id]||0)+pts;
      map[entry.name].total+=pts;
    });
  });
  return Object.values(map).sort((a,b)=>b.total-a.total);
}

// ── SHARE ──────────────────────────────────────────────────────────
function encodeShare(name,predictions,winner,fixtures,roundId){
  const d={n:name,p:fixtures.map(f=>[predictions[f.id].home,predictions[f.id].away]),w:winner,r:roundId};
  return btoa(unescape(encodeURIComponent(JSON.stringify(d))));
}
function decodeShare(str,fixtures){
  try{
    const d=JSON.parse(decodeURIComponent(escape(atob(str))));
    const predictions={};
    fixtures.forEach((f,i)=>{predictions[f.id]={home:d.p[i][0],away:d.p[i][1]};});
    return{name:d.n,predictions,winner:d.w,roundId:d.r};
  }catch{return null;}
}

// ── HOOKS ──────────────────────────────────────────────────────────
function useKickoffLock(kickoff){
  const [isLocked,setIsLocked]=useState(()=>new Date()>=kickoff);
  const [countdown,setCountdown]=useState("");
  useEffect(()=>{
    if(new Date()>=kickoff){setIsLocked(true);return;}
    const tick=()=>{
      const now=new Date();
      if(now>=kickoff){setIsLocked(true);setCountdown("");return;}
      const diff=kickoff-now;
      const d=Math.floor(diff/86400000),h=Math.floor((diff%86400000)/3600000);
      const m=Math.floor((diff%3600000)/60000),s=Math.floor((diff%60000)/1000);
      setCountdown(`${d}d ${String(h).padStart(2,"0")}h ${String(m).padStart(2,"0")}m ${String(s).padStart(2,"0")}s`);
    };
    tick();const id=setInterval(tick,1000);return()=>clearInterval(id);
  },[]);
  return{isLocked,countdown};
}

